
---

## .gitignore

```gitignore
# =========================
# SYSTEM FILES
# =========================
.DS_Store
Thumbs.db

# =========================
# ENVIRONMENT FILES
# =========================
.env
.env.local
.env.production

# =========================
# NODE MODULES
# =========================
node_modules/

# =========================
# BUILD FILES
# =========================
dist/
build/
.cache/

# =========================
# LOG FILES
# =========================
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# =========================
# TEMP FILES
# =========================
temp/
tmp/
*.tmp

# =========================
# EDITOR FILES
# =========================
.vscode/
.idea/

# =========================
# INTERNAL SCHOOL DATA
# =========================
administrasi/
absensi/
surat/
mbg/
data-siswa/
rapor/
internal/

# =========================
# LARGE DESIGN FILES
# =========================
*.psd
*.ai
*.xcf
*.raw

# =========================
# VIDEO FILES
# =========================
*.mp4
*.mov
*.avi
*.mkv

# =========================
# COMPRESSED FILES
# =========================
*.zip
*.rar
*.7z

# =========================
# CACHE FILES
# =========================
.cache/
*.cache
